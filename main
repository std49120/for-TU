    <script>
        function openTab(tabId) {
            // ซ่อนเนื้อหาทั้งหมด
            const contents = document.querySelectorAll('.tab-content');
            contents.forEach(content => {
                content.style.display = 'none';
            });

            // รีเซ็ตปุ่มทั้งหมดให้เป็นสีขาว (Inactive)
            const links = document.querySelectorAll('.tab-link');
            links.forEach(link => {
                link.classList.remove('bg-tu-pink-dark', 'text-white', 'shadow-md');
                link.classList.add('bg-white', 'text-gray-600');
            });

            // แสดงเนื้อหาที่เลือก
            document.getElementById(tabId).style.display = 'block';

            // เปลี่ยนสีปุ่มที่ถูกเลือก (Active)
            const activeBtn = document.getElementById('btn-' + tabId);
            activeBtn.classList.remove('bg-white', 'text-gray-600');
            activeBtn.classList.add('bg-tu-pink-dark', 'text-white', 'shadow-md');
        }
    </script>
